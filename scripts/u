#!/bin/bash
#******************************************************************************
# KickPi-OS Updater – Modernized for Debian Trixie
#******************************************************************************


set -Eeuo pipefail

#--- Farben ---
readonly BLACK='\033[0;39m'
readonly BLUE='\033[1;34m'
readonly GREEN='\033[1;32m'
readonly RED='\033[1;31m'
readonly GREY='\033[1;30m'
readonly NC='\033[0m'

#--- Konstanten ---
readonly REQUIRED_SPACE=5000000   # ~5GB in KB
readonly INSTALL_DIR="$HOME/KickPi-OS"
readonly REPO_URL="https://github.com/Jodels2002/KickPi-OS_up.git"

#--- Funktionen ---
display_info() {
    clear
    command -v toilet &>/dev/null && toilet "KickPi-OS" --metal || echo "KickPi-OS"
    echo -e "${GREY}KickPI-OS ROM Operating System and Libraries"
    echo "Version V2.0"
    echo "No Rights Reserved.${NC}\n"
}

check_disk_space() {
    local free_space
    free_space=$(df -k --output=avail "$HOME" | tail -n1)
    (( free_space >= REQUIRED_SPACE ))
}

delete_files() {
    local dir="$1"
    if [[ -d "$dir" ]]; then
        echo -e "${BLUE}Cleaning $dir...${NC}"
        rm -rf "${dir:?}/"*
    fi
}

run_step() {
    local description="$1"
    shift
    display_info
    echo -e "${GREEN}${description}...${NC}"
    "$@"
}

check_internet() {
    curl -s --head https://google.com >/dev/null
}

#--- Start ---
cd "$HOME"

display_info

echo -e "${BLACK}Checking disk space...${NC}"
df -H "$HOME"

if ! check_disk_space; then
    echo -e "${BLUE}Not enough space – cleaning...${NC}"

    delete_files "$HOME/pimiga2/disks/Work/Videos"
    delete_files "$HOME/Amiga/Install"

    echo -e "${BLACK}Rechecking disk space...${NC}"
    df -H "$HOME"

    if ! check_disk_space; then
        echo -e "${RED}Warning: Less than 5GB free.${NC}"
    fi
fi

#--- Systempflege ---
run_step "Fixing dpkg" sudo dpkg --configure -a || true
run_step "Fix broken packages" sudo apt -y --fix-broken install
run_step "Install missing deps" sudo apt -f -y install
run_step "Autoremove" sudo apt-get autoremove -y
run_step "Autoclean" sudo apt-get autoclean -y
run_step "Clean" sudo apt-get clean -y

#--- Internet prüfen ---
if check_internet; then
    run_step "Updating package lists" sudo apt update

    echo -e "${BLUE}Updating KickPi-OS...${NC}"

    rm -rf "$INSTALL_DIR"
    git clone --depth=1 "$REPO_URL" "$INSTALL_DIR"
    sudo chmod -R 755 "$INSTALL_DIR"

    sudo mkdir -p /opt/Backup

    # Sicherere Rechte setzen
    sudo cp -r "$INSTALL_DIR/scripts/"* /usr/local/bin/
    sudo chmod -R 755 /usr/local/bin

    sudo rm -rf /opt/KickPi-OS
    sudo cp -r "$INSTALL_DIR" /opt/

    # Script starten
    "$INSTALL_DIR/scripts/pikickme.sh"

else
    whiptail --msgbox "No internet connection detected." 10 50
fi
