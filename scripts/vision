#!/usr/bin/env bash


# Colors
BLACK='\033[0;39m'
BLUE='\033[1;34m'
GREEN='\033[1;32m'
RED='\033[1;31m'
GREY='\033[1;30m'
NC='\033[0m'

APP_DIR="/opt/AmigaVision"
ARCHIVE="AmigaVision-Emulators-2026.04.26.7z"
ARCHIVE_URL="https://archive.org/download/amigavision-emulators/${ARCHIVE}"
MIN_SPACE=10000000   # ~10GB in KB

print_header() {
    clear
    toilet "KickPi-OS" --metal
    echo -e "${GREY}KickPi-OS-OS ROM Operating System and Libraries${NC}"
    echo "Version V2.0 2020-2021 KickPi-OS"
    echo "No Rights Reserved."
    echo
}

check_disk_space() {
    echo -ne "${BLACK}Checking free disk space... ${NC}"
    local free
    free=$(df -k --output=avail "$PWD" | tail -n1)

    if (( free < MIN_SPACE )); then
        echo -e "\n${RED}Installation aborted: Not enough disk space!${NC}"
        echo -e "${BLUE}You need at least 10GB free.${NC}"
        exit 1
    fi
}

download_archive() {
    if [[ ! -f "${APP_DIR}/${ARCHIVE}" ]]; then
        clear
        toilet "KickPi-OS" --metal
        echo -e "${GREY}KickPi-OS-OS ROM Operating System and Libraries${NC}"
        echo "Version V2.0 2020-2021 KickPi-OS"
        echo "No Rights Reserved."
        echo
        echo -e "${GREEN}Downloading AmigaVision...${NC}"
        mkdir -p "$APP_DIR"
        cd "$APP_DIR"
        wget -q --show-progress "$ARCHIVE_URL"
    fi
}

extract_archive() {
    cd "$APP_DIR"
    if [[ ! -f "${APP_DIR}/Amiberry/Harddrives/AmigaVision.hdf" ]]; then
        clear
        toilet "KickPi-OS" --metal
        echo -e "${GREY}KickPi-OS-OS ROM Operating System and Libraries${NC}"
        echo "Version V2.0 2020-2021 KickPi-OS"
        echo "No Rights Reserved."
        echo
        echo -e "${GREEN}Extracting files...${NC}"
        7z x "$ARCHIVE" >/dev/null
    fi
}
install_files() {
    echo -e "${GREEN}Finalizing installation...${NC}"

    sudo install -m 644 /opt/KickPi-OS/Amiga/AmigaVision/AmigaVision.desktop /usr/share/applications/
    cp -f /opt/KickPi-OS/Amiga/AmigaVision/*.uae /opt/Amiga/conf/
    cp -f "${APP_DIR}"/Amiberry/Roms/*.rom /opt/Amiga/kickstarts/ || true
}

run_emulator() {
    cd /opt/Amiga
    ./amiberry_dev --config conf/AmigaVision.uae -G
}

# ---- MAIN ----
print_header
check_disk_space
download_archive
extract_archive
print_header
echo -e "${GREEN}Ready — have fun :-)${NC}"

install_files
run_emulator
